{
  "manifest_version": 3,
  "name": "HQ",
  "version": "2.3.0",
  "description": "统计在横琴驻留的天数",
  "permissions": [
    "geolocation",
    "storage",
    "alarms",
    "offscreen"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
